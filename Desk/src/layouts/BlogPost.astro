---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE } from '../consts';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category } = Astro.props;
import fs from 'node:fs';
import path from 'node:path';
function findImage(basePath: string) {
	if (!basePath) return '';
	const exts = ['.webp', '.jpg', '.png', '.jpeg'];
	const publicDir = path.join(process.cwd(), 'public');
	let base = basePath;
	if (basePath.match(/\.(jpg|jpeg|png|webp)$/i)) {
		base = basePath.replace(/\.(jpg|jpeg|png|webp)$/i, '');
	}
	for (const ext of exts) {
		if (fs.existsSync(path.join(publicDir, base + ext))) {
			return base + ext;
		}
	}
	return '';
}
const resolvedHeroImage = findImage(heroImage || '');

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const jsonLd = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	"headline": title,
	"description": description,
	...(resolvedHeroImage ? { image: new URL(resolvedHeroImage, Astro.site).href } : {}),
	...(pubDate ? { datePublished: new Date(pubDate).toISOString() } : {}),
	dateModified: new Date(updatedDate || pubDate || Date.now()).toISOString(),
	author: { "@type": "Organization", name: SITE_TITLE },
	publisher: { "@type": "Organization", name: SITE_TITLE },
	mainEntityOfPage: { "@type": "WebPage", "@id": canonicalURL },
};
---

<html lang="ja">
	<head>
		<BaseHead title={title} description={description} image={resolvedHeroImage} />
		<script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
		<style>
			main {
				width: 75%;
				max-width: none;
				margin: 0 auto;
			}
			article {
				width: 75%;
				margin: 0 auto;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 4px;
				border: 1px solid rgba(51,46,42,0.12);
			}
			.prose {
				width: 100%;
				max-width: 100%;
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
				background: #ffffff;
				border: 1px solid rgba(51,46,42,0.08);
				border-radius: 4px;
			}
			:global(.prose table) {
				width: 100%;
				border-collapse: collapse;
				margin: 2em 0;
				font-size: 0.95em;
			}
			:global(.prose th), :global(.prose td) {
				border: 1px solid rgba(128, 128, 128, 0.2);
				padding: 12px 16px;
				text-align: left;
			}
			:global(.prose th) {
				background-color: var(--accent, #C17F59);
				color: #fff;
				font-weight: bold;
			}
			:global(.prose tr:nth-child(even)) {
				background-color: rgba(128, 128, 128, 0.05);
			}

			.prose::after {
				content: "";
				display: table;
				clear: both;
			}
			.prose img {
				float: left;
				max-width: 50%;
				margin: 0 1.5em 1em 0;
				border-radius: 8px;
			}
			.faq-container { margin-top: 2rem; display: flex; flex-direction: column; gap: 1rem; clear: both; }
			.faq-block { background-color: #FBFAF7; border-left: 3px solid var(--accent); border-radius: 2px; padding: 1.25rem; }
			.faq-q { color: var(--accent-dark); font-weight: bold; font-size: 1.1rem; margin-bottom: 0.5rem; }
			.faq-a { color: #5C5650; line-height: 1.6; }
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{resolvedHeroImage && <img width="1020" height="510" src={resolvedHeroImage} alt={title || "Hero Image"} onerror="this.style.display='none'" />}
				</div>
				<div class="prose">
					{category && (
						<div class="article-category" style="text-align: center; margin-bottom: 0.5em;">
							<span style="background: var(--accent, #C17F59); color: #fff; padding: 4px 12px; border-radius: 20px; font-size: 0.85em; text-transform: uppercase; letter-spacing: 1px;">{category}</span>
						</div>
					)}
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
