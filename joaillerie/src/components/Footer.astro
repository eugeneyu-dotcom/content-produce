---
const today = new Date();
---

<footer class="luxury-footer">
	<div class="footer-content">
		<div class="footer-brand">
			<div class="maxora-logo">
				Maxora.ai
			</div>
			<p class="brand-desc">
				L'intelligence artificielle au service de la beauté, de l'histoire et de la culture. Nous créons des expériences digitales immersives pour décrypter le langage invisible du monde.
			</p>
			<div class="copyright">
				&copy; {today.getFullYear()} Joaillerie et Symbolique & Maxora.ai. Tous droits réservés.
			</div>
		</div>
		
		<div class="footer-links">
			<h3>Liens Rapides</h3>
			<a href="/politique-de-confidentialite" class="footer-btn">Politique de Confidentialité</a>
			<a href="mailto:eugeneyu@maxora.ai" class="footer-btn">Contactez-nous</a>
		</div>
	</div>
</footer>
<style>
	.luxury-footer {
		background-color: var(--accent-dark, #331438);
		color: #ebd5f5;
		padding: 5em 2em;
		margin-top: 4em;
		font-family: 'IBM Plex Sans', sans-serif;
	}
	.footer-content {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		gap: 4em;
	}
	.footer-brand {
		flex: 2;
		min-width: 300px;
	}
	.maxora-logo {
		font-family: 'Playfair Display', serif;
		font-size: 2.5em;
		font-weight: 700;
		color: #fff;
		margin-bottom: 0.5em;
		letter-spacing: 1px;
	}
	.brand-desc {
		font-size: 1.05em;
		line-height: 1.8;
		opacity: 0.85;
		margin-bottom: 2em;
		max-width: 500px;
	}
	.copyright {
		font-size: 0.9em;
		opacity: 0.6;
		border-top: 1px solid rgba(255,255,255,0.1);
		padding-top: 1.5em;
		margin-top: 1em;
	}
	.footer-links {
		flex: 1;
		min-width: 250px;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 1em;
	}
	.footer-links h3 {
		font-family: 'Playfair Display', serif;
		font-size: 1.5em;
		color: #fff;
		margin-bottom: 1em;
		font-weight: 400;
	}
	.footer-btn {
		display: inline-block;
		padding: 10px 25px;
		background-color: rgba(255,255,255,0.05);
		border: 1px solid rgba(255,255,255,0.2);
		color: #fff;
		text-decoration: none;
		border-radius: 4px;
		transition: all 0.3s ease;
		font-size: 0.95em;
		width: 100%;
		text-align: center;
		box-sizing: border-box;
	}
	.footer-btn:hover {
		background-color: #fff;
		color: var(--accent-dark, #331438);
	}
</style>
