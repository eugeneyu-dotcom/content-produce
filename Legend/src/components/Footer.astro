---
const today = new Date();
---

<footer class="eerie-footer">
	<div class="footer-content">
		<div class="footer-brand">
			<div class="maxora-logo">
				Maxora.ai
			</div>
			<p class="brand-desc">
				Artificial intelligence uncovering the mysteries, myths, and legends that shape human culture. We create digital experiences to explore the terrifying unknown.
			</p>
			<div class="copyright">
				&copy; {today.getFullYear()} Global Urban Legends & Maxora.ai. All rights reserved.
			</div>
		</div>
		
		<div class="footer-links">
			<h3>Quick Links</h3>
			<a href="/privacy-policy" class="footer-btn">Privacy Policy</a>
			<a href="mailto:eugeneyu@maxora.ai" class="footer-btn">Contact Us</a>
		</div>
	</div>
</footer>
<style>
	.eerie-footer {
		background-color: var(--accent-dark, #7A1212);
		color: #D6D3CE;
		padding: 5em 2em;
		margin-top: 4em;
		font-family: 'Courier Prime', monospace;
		border-top: 2px solid var(--accent, #B91C1C);
	}
	.footer-content {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		gap: 4em;
	}
	.footer-brand {
		flex: 2;
		min-width: 300px;
	}
	.maxora-logo {
		font-family: 'Playfair Display', serif;
		font-size: 2.5em;
		font-weight: 700;
		color: #D6D3CE;
		margin-bottom: 0.5em;
		letter-spacing: 1px;
	}
	.brand-desc {
		font-size: 1.05em;
		line-height: 1.8;
		opacity: 0.85;
		margin-bottom: 2em;
		max-width: 500px;
	}
	.copyright {
		font-size: 0.9em;
		opacity: 0.6;
		border-top: 1px solid rgba(232, 226, 213, 0.2);
		padding-top: 1.5em;
		margin-top: 1em;
	}
	.footer-links {
		flex: 1;
		min-width: 250px;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 1em;
	}
	.footer-links h3 {
		font-family: 'Special Elite', cursive;
		font-size: 1.8em;
		color: #D6D3CE;
		margin-bottom: 1em;
		font-weight: 400;
	}
	.footer-btn {
		display: inline-block;
		padding: 10px 25px;
		background-color: rgba(232, 226, 213, 0.05);
		border: 1px solid rgba(232, 226, 213, 0.3);
		color: #D6D3CE;
		text-decoration: none;
		border-radius: 4px;
		transition: all 0.3s ease;
		font-size: 0.95em;
		width: 100%;
		text-align: center;
		box-sizing: border-box;
	}
	.footer-btn:hover {
		background-color: #0D0D0D;
		color: #D6D3CE;
		border-color: var(--accent, #B91C1C);
	}
</style>