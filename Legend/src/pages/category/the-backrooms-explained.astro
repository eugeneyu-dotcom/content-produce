    <div style="display: flex; flex-wrap: wrap; gap: 10px;">
        <span class="keyword-btn pending" style="padding: 8px 16px; background-color: #2A2723; color: #8A8478; border-radius: 2px; font-size: 0.95rem; text-transform: uppercase; letter-spacing: 0.08em; border: 1px solid rgba(232,226,213,0.15); cursor: not-allowed;">#why empty malls are scary</span>
        <span class="keyword-btn pending" style="padding: 8px 16px; background-color: #2A2723; color: #8A8478; border-radius: 2px; font-size: 0.95rem; text-transform: uppercase; letter-spacing: 0.08em; border: 1px solid rgba(232,226,213,0.15); cursor: not-allowed;">#liminal space photography aesthetics</span>
        <span class="keyword-btn pending" style="padding: 8px 16px; background-color: #2A2723; color: #8A8478; border-radius: 2px; font-size: 0.95rem; text-transform: uppercase; letter-spacing: 0.08em; border: 1px solid rgba(232,226,213,0.15); cursor: not-allowed;">#psychology of empty hallways</span>
        <span class="keyword-btn pending" style="padding: 8px 16px; background-color: #2A2723; color: #8A8478; border-radius: 2px; font-size: 0.95rem; text-transform: uppercase; letter-spacing: 0.08em; border: 1px solid rgba(232,226,213,0.15); cursor: not-allowed;">#dreamcore and weirdcore origins</span>
        <span class="keyword-btn pending" style="padding: 8px 16px; background-color: #2A2723; color: #8A8478; border-radius: 2px; font-size: 0.95rem; text-transform: uppercase; letter-spacing: 0.08em; border: 1px solid rgba(232,226,213,0.15); cursor: not-allowed;">#feeling of being watched in empty buildings</span>
    </div>
</section>




        


<div class="category-faq-section" style="margin-top: 60px; padding: 40px 30px; background: #1A1816; border-radius: 12px; border: 1px solid rgba(185,28,28,0.4);">
